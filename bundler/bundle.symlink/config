---
BUNDLE_JOBS: "4"
BUNDLE_IGNORE_MESSAGES__HTTPARTY: "true"
BUNDLE_GIT__ALLOW_INSECURE: "true"
BUNDLE_GEM__TEST: "false"
BUNDLE_GEM__MIT: "false"
BUNDLE_GEM__COC: "false"
BUNDLE_BUILD__PUMA: "--with-cflags=-Wno-error=implicit-function-declaration"
BUNDLE_BUILD__THIN: "--with-cflags=-Wno-error=implicit-function-declaration"
BUNDLE_BUILD__MYSQL2: "--with-mysql-dir=/opt/homebrew/opt/mysql-client"
BUNDLE_BUILD__PG: "--with-pg-include=/Applications/Postgres.app/Contents/Versions/14/include/libpq-fe.h --with-pg-lib=/Applications/Postgres.app/Contents/Versions/14/lib/libpq.dylib"
